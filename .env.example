# ══════════════════════════════════════════════════════════════════════════
# ai-video-canvas 环境变量完整模板
#
# 用法：复制本文件为项目根目录 .env（Windows: copy .env.example .env），按需填写。
# ⚠️ 改动 .env 后必须重启服务才生效：net stop AVC-App && net start AVC-App，
#    或 pm2 restart avc；跑一次「系统更新」/update.bat 也会自动重启。
# ✅ 部署完成后到 管理后台 →「配置体检」页签逐项核对配置是否就位。
#
# 注意：以下配置存【数据库】、在【管理后台】页面配置，不在本文件：
#   SMTP 邮件（注册认证页签）· 公网隧道 token（公网隧道页签）· kie 分发子密钥
#   （kie.ai 密钥页签）· 自建 LLM 地址/Key/模型（模型管理›自建 LLM）· 存储持久化
#   开关（存储设置页签）· ComfyUI 运维 SSH（运维中心）
# ══════════════════════════════════════════════════════════════════════════

# ── 1. 核心（生产必配）──────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
# MySQL 连接串（deploy.bat 一键部署会自动生成本节全部内容）
DATABASE_URL=mysql://root:数据库密码@localhost:3306/ai_video_canvas
# 会话签名密钥：随机 32+ 字符。生产环境不设会【拒绝启动】
JWT_SECRET=
# 管理员（owner）邮箱：用此邮箱注册/登录自动获得超级管理员。第三方部署务必改成自己的！
OWNER_EMAIL=

# ── 2. 登录 / 认证（可选）───────────────────────────────────────────────────
# 平台 OAuth（不配则用邮箱注册登录）
# OAUTH_SERVER_URL=
# VITE_APP_ID=
# OWNER_OPEN_ID=
# Google 登录（CLIENT_ID 与 SECRET 两个都设才启用；回调地址默认从请求推导）
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=

# ── 3. 对象存储（成片/素材落盘，强烈建议配置）────────────────────────────────
# 自建 MinIO：跑 deploy\setup-minio.bat 一键搭建并自动写入以下 S3_* 变量
# S3_ENDPOINT=http://127.0.0.1:9000
# S3_BUCKET=avc-chat
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_REGION=us-east-1
# S3_FORCE_PATH_STYLE=true
# 浏览器可直连的公网存储地址（不设=下载/上传经应用服务器中转，一般无需设置）
# S3_PUBLIC_ENDPOINT=
# 或使用内置 Forge 网关（与 S3 二选一；两者都配时 S3 优先）
# BUILT_IN_FORGE_API_URL=
# BUILT_IN_FORGE_API_KEY=

# ── 4. AI 平台密钥（按需，不设=对应模型不可用）──────────────────────────────
# kie.ai 公用 key（后台「kie.ai 密钥」页签还可给用户分发子密钥，那些存数据库）
# KIE_API_KEY=
# kie 分发子密钥的入库加密盐（要用密钥分发功能就必须设；随机 32+ 字符）
# KIE_KEY_SECRET=
# POYO_API_KEY=
# OpenAI（配音 TTS 与「自定义 OpenAI 模型」都用它）
# OPENAI_API_KEY=
# OPENAI_MODEL=
# Anthropic「自定义 Anthropic 模型」（⚠️ 若走第 6 节订阅桥接则不要设它，见下）
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=
# Higgsfield（KEY 与 SECRET 必须成对设置）
# HIGGSFIELD_API_KEY=
# HIGGSFIELD_API_SECRET=

# ── 5. ComfyUI（可选）───────────────────────────────────────────────────────
# COMFYUI_BASE_URL=http://127.0.0.1:8188
# ComfyUI 官方云（platform.comfy.org 生成 API Key，需 Creator/Pro 套餐）
# COMFYUI_CLOUD_API_KEY=
# COMFYUI_CLOUD_BASE_URL=https://cloud.comfy.org
# 运维中心 SSH 凭据的入库加密盐（要在运维中心添加 SSH 服务器就必须设）
# SSH_KEY_SECRET=

# ── 6. 本机 Claude / GPT 订阅桥接（可选；详见 docs/本机claude桥接.md）────────
# 桥接口令：设了才启用 /api/claude-bridge；后台「自建 LLM」的 API Key 必须填相同值
# CLAUDE_LOCAL_BRIDGE_KEY=
# Claude 订阅授权（claude setup-token 所得）
# ⚠️ 设了它就【不要】再设 ANTHROPIC_API_KEY——claude 会优先用 API Key 变按量计费
# CLAUDE_CODE_OAUTH_TOKEN=
# CLI 路径覆盖（Windows npm 全局标准路径 %APPDATA%\npm 会自动探测，通常无需设置）
# CLAUDE_BIN=
# CODEX_BIN=
# ⚠️ 切勿设 CODEX_API_KEY——它优先级高于 ChatGPT 订阅凭证，设了就绕过订阅按量计费。
# GPT 侧凭证是文件不是变量：把已登录机器的 ~/.codex/auth.json 拷到服务器同路径
# （Windows：C:\Users\你\.codex\auth.json）。

# ── 7. 工程智能体「代码任务」（默认关闭；详见 docs/phase2-启用清单.md）────────
# SUPER_AGENT_CODE_ENABLED=1
# SUPER_AGENT_CODE_ALLOW_BASH=1
# SUPER_AGENT_PERMISSION_CMD=node
# SUPER_AGENT_PERMISSION_ARGS=["项目绝对路径/dist/permissionMcpServer.cjs"]
# SUPER_AGENT_AUTO_INSTALL=1

# ── 8. HTTPS / 系统工具 / 其它（可选）───────────────────────────────────────
# 自签 HTTPS：跑 deploy\setup-https.bat 生成证书后自动生效（默认路径如下）
# HTTPS_CERT_FILE=certs/cert.pem
# HTTPS_KEY_FILE=certs/key.pem
# HTTP_REDIRECT_PORT=80
# ffmpeg 不在 PATH 时指定完整路径（视频导出/剪辑必需 ffmpeg）
# FFMPEG_PATH=
# FFPROBE_PATH=
# 下载水印字体路径
# WATERMARK_FONT_PATH=
# cloudflared 二进制/数据目录（默认 .cloudflared）
# CLOUDFLARED_DIR=
# 文件中继（跨机传文件）
# RELAY_DIR=
# RELAY_MAX_BYTES=
# RELAY_RETENTION_DAYS=
# RELAY_TOKEN=
